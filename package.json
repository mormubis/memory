{
  "name": "@mormubis/memory",
  "type": "module",
  "version": "0.4.2",
  "description": "Memory infrastructure library — store, version, search, and decay knowledge over time",
  "repository": {
    "type": "git",
    "url": "https://github.com/mormubis/memory"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "/dist/"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' '*.mjs' --fix && tsc --noEmit",
    "lint:ci": "eslint 'src/**/*.ts' '*.mjs' --max-warnings 0 && tsc --noEmit",
    "lint:style": "eslint 'src/**/*.ts' '*.mjs' --fix",
    "lint:types": "tsc --noEmit",
    "format": "pnpm run format:ci --write",
    "format:ci": "prettier -l \"**/*.+(css|js|json|jsx|md|mjs|mts|ts|tsx|yml|yaml)\"",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@huggingface/transformers": "^4.2.0",
    "@types/better-sqlite3": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^70.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
